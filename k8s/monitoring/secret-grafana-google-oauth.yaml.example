# ──────────────── Grafana Google OAuth Secret ────────────────
# Template: copy this file to secret-grafana-google-oauth.yaml,
# fill in your values, then apply to the cluster.
#
# DO NOT commit the real secret-grafana-google-oauth.yaml — it is
# listed in .gitignore. Only this .example file is tracked by git.
#
# How to obtain Client ID and Client Secret:
#   1. Go to https://console.cloud.google.com/apis/credentials
#   2. Create → OAuth client ID → Application type: Web application
#   3. Authorized redirect URIs: https://grafana.kouni.io/login/google
#   4. Copy the generated Client ID and Client Secret below.
#
# Apply:
#   kubectl apply -f k8s/monitoring/secret-grafana-google-oauth.yaml
# ─────────────────────────────────────────────────────────────
apiVersion: v1
kind: Secret
metadata:
  name: grafana-google-oauth
  namespace: monitoring
  labels:
    alwaysfree: "true"
type: Opaque
stringData:
  GF_AUTH_GOOGLE_CLIENT_ID: "your-client-id.apps.googleusercontent.com"
  GF_AUTH_GOOGLE_CLIENT_SECRET: "your-client-secret"
