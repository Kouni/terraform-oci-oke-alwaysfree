# ──────────────── OCI Authentication ────────────────
# Option 1: Config file profile (recommended — reads auth from ~/.oci/config)
config_file_profile = "DEFAULT"

# Option 2: Direct credentials (uncomment below, comment out Option 1)
# tenancy_ocid     = "ocid1.tenancy.oc1..example"
# user_ocid        = "ocid1.user.oc1..example"
# fingerprint      = "aa:bb:cc:dd:ee:ff:00:11:22:33:44:55:66:77:88:99"
# private_key_path = "~/.oci/oci_api_key.pem"
# region           = "ap-tokyo-1"

# ──────────────── Compartment ────────────────
compartment_ocid = "ocid1.tenancy.oc1..example"  # Use tenancy OCID for root compartment

# ──────────────── Cluster ────────────────
# cluster_name       = "formosa"
# kubernetes_version = null  # null = latest available; pin with e.g. "v1.32.1"

# ──────────────── Node Pool ────────────────
# Always Free limits: 4 OCPUs, 24 GB RAM, 200 GB block volume total
# node_count              = 1
# node_ocpus              = 4
# node_memory_in_gbs      = 24
# boot_volume_size_in_gbs = 64
# ssh_public_key          = "ssh-rsa AAAA..."

# ──────────────── Budget Alert ────────────────
# enable_budget_alert = true
notification_email    = "you@example.com"

# ──────────────── Cluster Add-ons ────────────────
# enable_metrics_server        = true
# metrics_server_chart_version = null  # null = latest; pin with e.g. "3.12.2"

# ──────────────── NFS Storage ────────────────
# Boot (64 GB) + NFS (136 GB) = 200 GB Always Free limit
# enable_nfs_storage     = false
# nfs_volume_size_in_gbs = 136

# ──────────────── Tags ────────────────
# freeform_tags = {
#   "alwaysfree" = "true"
#   "Owner"      = "Kouni"
# }

# ──────────────── n8n ────────────────
# Prerequisites:
#   1. enable_nfs_storage = true  (n8n uses the NFS StorageClass for persistent data)
#   2. enable_cloudflare_tunnel = true  (Cloudflare Tunnel provides ingress — no OCI LB needed)
#   3. Add Public Hostname in Cloudflare Dashboard: http://n8n-main.n8n.svc.cluster.local:5678
#   4. For new deployments: generate key with `openssl rand -hex 32`
#      For existing clusters: extract with `kubectl get secret n8n-secrets -n n8n -o jsonpath='{.data.N8N_ENCRYPTION_KEY}' | base64 -d`
# enable_n8n              = false
# n8n_namespace           = "n8n"
# n8n_pvc_size            = "5Gi"
# n8n_secret_name         = "n8n-secrets"
# n8n_chart_version       = null  # null = latest; pin with e.g. "0.3.0"
# n8n_image_tag           = "latest"  # pin with e.g. "1.94.1" for reproducible deployments
# n8n_host                = "n8n.example.com"
# n8n_encryption_key      = "replace-with-openssl-rand-hex-32-output"  # sensitive — do not commit

# ──────────────── Cloudflare Tunnel ────────────────
# Prerequisites:
#   1. Create Tunnel: https://one.dash.cloudflare.com → Networks → Tunnels
#   2. Copy the tunnel token — it is used as cloudflare_tunnel_token below
# enable_cloudflare_tunnel      = false
# cloudflare_tunnel_namespace   = "tunnel"
# cloudflared_secret_name       = "cloudflare-tunnel"
# cloudflared_image_tag         = "latest"  # pin with e.g. "2025.4.1" for reproducible deployments
# cloudflare_tunnel_token       = "eyJhIjoixx..."  # sensitive — do not commit
